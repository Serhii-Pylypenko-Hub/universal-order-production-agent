# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
MANAGER_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=        # Random string; used to verify Telegram webhook requests

# ── Bot mode ───────────────────────────────────────────────────────────────────
BOT_MODE=polling                 # polling (dev) | webhook (production)
WEBHOOK_URL=                     # Required in webhook mode, e.g. https://your-domain.com/webhook
PORT=3000                        # HTTP server port (webhook mode)

# ── AI ─────────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
AI_MODEL=openai/gpt-4o-mini

# ── Google Sheets ───────────────────────────────────────────────────────────────
GOOGLE_SHEETS_ID=                # Spreadsheet ID from the URL
GOOGLE_SERVICE_ACCOUNT_JSON=     # Base64-encoded service account JSON (recommended for env)
GOOGLE_SERVICE_ACCOUNT_KEY_FILE= # Path to service account JSON file (alternative to above)

# ── Google Calendar ─────────────────────────────────────────────────────────────
GOOGLE_CALENDAR_ID=              # Calendar ID, e.g. user@gmail.com or resource ID

# ── Local storage (used when GOOGLE_SHEETS_ID is not set) ───────────────────────
LOCAL_DATA_PATH=./data/local_workspace.json
